{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AoE3 Replay Analyzer",
  "version": "0.1.0",
  "identifier": "com.aoe3capture.replay-analyzer",
  "build": {
    "frontendDist": "../viewer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AoE3 Replay Analyzer",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
